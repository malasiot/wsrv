{% extends 'base.html.twig' %}

{% block title %}{{ 'upload.title'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
    <form id="editRouteForm" data-route-id="{{ route.id }}" enctype="multipart/form-data">
        <div class="card-body bg-light">
            <div class="row g-4">
                
                {# Left Column: Details & Photo Upload #}
                <div class="col-lg-5">
                    <div class="card h-100 border-0 shadow-xs">
                        <div class="card-body">
                            {# Route Title #}
                            <div class="mb-3">
                                <label for="routeTitle" class="form-label fw-bold">{{ 'route.form.title'|trans }}</label>
                                <input type="text" class="form-control" id="routeTitle" name="title" value="{{ route.title }}" >
                            </div>

                            {# Difficulty Level #}
                            <div class="mb-3">
                                <label for="routeDifficulty" class="form-label fw-bold">{{ 'route.form.difficulty'|trans }}</label>
                                <select class="form-select" id="routeDifficulty" name="difficulty">
                                    <option value="easy" {% if route.difficulty == 'easy' %}selected{% endif %}>{{ 'route.difficulty.easy'|trans }}</option>
                                    <option value="medium" {% if route.difficulty == 'medium' %}selected{% endif %}>{{ 'route.difficulty.medium'|trans }}</option>
                                    <option value="hard" {% if route.difficulty == 'hard' %}selected{% endif %}>{{ 'route.difficulty.hard'|trans }}</option>
                                </select>
                            </div>

                            {# Length & Duration #}
                            <div class="row g-2 mb-4">
                                <div class="col-6">
                                    <label for="routeLength" class="form-label fw-bold">{{ 'route.form.length'|trans }}</label>
                                    <div class="input-group">
                                        <input type="number" step="0.1" class="form-control" id="routeLength" name="length" value="{{ route.length }}" >
                                        <span class="input-group-text">km</span>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <label for="routeDuration" class="form-label fw-bold">{{ 'route.form.duration'|trans }}</label>
                                    <div class="input-group">
                                        <input type="number" class="form-control" id="routeDuration" name="duration" value="{{ route.duration }}" >
                                        <span class="input-group-text">{{ 'route.form.hours'|trans }}</span>
                                    </div>
                                </div>
                            </div>

                            {# New: Pictures Upload Dropzone/Input Area #}
                           <div class="border-top pt-3">
                                  {% include 'routes/gallery.html' with {
                                     'gallery_id': 'global-gallery',
                                      'gallery_title':  "global-gallery" | trans,
                                      'route_id': route.id,
                                     'images': route.photos
                                } %}
                            </div>
                        </div>
                    </div>
                </div>

                {# Right Column: Multilingual Description #}
                <div class="col-lg-7">
                    <div class="card h-100 border-0 shadow-xs">
                        <div class="card-body d-flex flex-column">
                            <label class="form-label fw-bold mb-2">{{ 'route.form.description'|trans }}</label>
                      
                            <div class="border border-top-0 rounded-bottom p-3 flex-grow-1 bg-white" id="langTabsContent">
                                <div class="h-100" id="lang-el" role="tabpanel" aria-labelledby="el-tab">
                                    <textarea class="form-control h-100 min-vh-25" id="descriptionEl" name="desc" rows="12" >{{ route.desc }}</textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        
        {# Bottom Action Bar #}
        <div class="card-footer bg-white d-flex justify-content-end gap-2 py-3">
            <a href="/admin/dashboard/" class="btn btn-secondary px-4" id="btnCancelBottom">
                {{ 'cancel'|trans }}
            </a>
            <button type="submit" 
                    class="btn btn-success px-5 fw-bold" 
                    id="btnSubmitRoute" 
                    data-txt-save="{{ 'route.form.update'|trans }}" 
                    data-txt-saving="{{ 'route.form.saving'|trans }}">
                {{ 'route.form.update'|trans }}
            </button>
        </div>
    </form>

   <div class="container my-4" id="waypoints-management-wrapper" data-route-id="{{ route.id }}">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>{{'waypoints'|trans}}</h3>
        <button class="btn btn-outline-primary btn-sm" id="add-waypoint-btn">
            <i class="bi bi-geo-alt-fill me-1"></i>{{'waypoint.add.new'|trans}}
        </button>
    </div>

    <!-- Flex Layout Flex Container Column Stack -->
    <div class="d-flex flex-column gap-3" id="waypoints-list-container">
        {% for wpt in route.waypoints %}
            <div class="card shadow-sm waypoint-list-item" data-wpt-id="{{ wpt.id }}">
                <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    
                    <!-- Content Block Context Section -->
                    <div class="waypoint-info flex-grow-1">
                        <h5 class="card-title text-primary mb-1 waypoint-title-text">{{ wpt.name }}</h5>
                        <p class="card-text text-muted small mb-0 waypoint-desc-text">{{ wpt.desc }}</p>
                    </div>
                    
                    <!-- Action Operation Trigger Layout Buttons -->
                    <div class="waypoint-actions d-flex align-items-center gap-2 flex-shrink-0">
                        <!-- Toggles the associated gallery display wrapper container component if desired -->
                       <button class="btn btn-light btn-sm d-inline-flex align-items-center gap-2" type="button" data-bs-toggle="collapse" data-bs-target="#wpt-gallery-collapse-{{ wpt.id }}" aria-expanded="false" title="View Photos">
                            <i class="bi bi-images"></i>
                            <span>{{'photos'|trans}}</span>
                            <!-- Dynamic Counter Badge -->
                            <span class="badge bg-secondary rounded-pill wpt-photo-count-badge">
                             {{ wpt.photos|length }}
                            </span>
                        </button>
                        <button class="btn btn-warning btn-sm edit-waypoint-btn" title="Edit Content">
                            <i class="bi bi-pencil-square"></i>
                        </button>
                        <button class="btn btn-outline-danger btn-sm delete-waypoint-btn" title="Delete Point">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>

                </div>
                 <!-- Collapsible Waypoint Gallery Component Context Container -->
                    <div class="collapse" id="wpt-gallery-collapse-{{ wpt.id }}">
                        <div class="pt-3 bg-light rounded border">
                            
                            <!-- REUSING THE EXACT SAME GALLERY COMPONENT -->
                            {% include 'routes/gallery.html' with {
                                'id': 'gallery-wpt-' ~ wpt.id,
                                'gallery_title': 'Photos for ' ~ wpt.name,
                                'route_id': route.id,
                                'wpt_id': wpt.id,
                                'images': wpt.photos 
                            } %}
                            
                        </div>
                    </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-4 text-muted border rounded bg-light empty-waypoints-msg">
                {{'no-waypoints'|trans}}
            </div>
        {% endfor %}
    </div>
</div>

{%include 'routes/waypoints.html' %}


{% endblock %}

{% block javascripts %}
  <script src="/public/js/gallery.js"></script>
    <script src="/public/js/waypoints.js"></script>
<script>
$(document).ready(function() {

    var $form = $('#editRouteForm');
    var routeId = $form.data('route-id'); // Read the specific route ID safely

  

    // AJAX PUT / POST Handler
    $form.on('submit', function(e) {
        e.preventDefault();
        
        var formData = new FormData(this);
        var $submitBtn = $('#btnSubmitRoute');
        
       
        $submitBtn.prop('disabled', true)
                  .html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> {{ "saving" | trans }}');

        $.ajax({
            url: '/api/routes/update/' + routeId, // RESTful endpoint using dynamic ID
            type: 'POST', // Use POST because standard multipart/form-data files struggle natively over standard PUT requests
            data: formData,
            processData: false, 
            contentType: false, 
            success: function(response) {
                if ( response.success === false ) {
                     alert('Error updating route: ');
                }
                 $submitBtn.prop('disabled', false).text('{{ "update" | trans }}');
            },
            error: function(xhr) {
                alert('Error editing route: ' + xhr.responseText);
                $submitBtn.prop('disabled', false).text('{{ "update" | trans }}');
            }
        });
    });

});
</script>
{% endblock %}