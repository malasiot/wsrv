{% extends 'base.html.twig' %}

{% block title %}{{ 'upload.title'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">{{ 'upload.form.heading'|trans }}</h5>      
    </div>
    <form id="newRouteForm" enctype="multipart/form-data">
        <div class="card-body bg-light">
            <div class="row g-4">
                
                {# Left Column: File, Title, Specs #}
                <div class="col-lg-12">
                    <div class="card h-100 border-0 shadow-xs">
                        <div class="card-body">
                            {# GPS File Upload #}
                            <div class="mb-3">
                                <label for="gpsFile" class="form-label fw-bold">{{ 'upload.route.gps_file'|trans }}</label>
                                <input class="form-control form-control-lg" type="file" id="gpsFile" name="gps_file" accept=".gpx,.kml" required>
                            </div>
                        </div>
                    </div>
                </div>

        

            </div>
        </div>
        
        {# Bottom Action Bar #}
        <div class="card-footer bg-white d-flex justify-content-end gap-2 py-3">
            <a href="/admin/dashboard/" class="btn btn-secondary px-4" id="btnCancelBottom">
        {{ 'cancel'|trans }}
            </a>
            <button type="submit" class="btn btn-success px-5 fw-bold" id="btnSubmitRoute">{{ 'submit'|trans }}</button>
        </div>
    </form>
</div>
{% endblock %}

{% block javascripts %}
<script>
$(document).ready(function() {
    $('#newRouteForm').on('submit', function(e) {
        e.preventDefault();
        var formData = new FormData(this);
        var $submitBtn = $('#btnSubmitRoute');
        
        $submitBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> {{ "route.form.saving"|trans }}...');

        $.ajax({
            url: '/routes/create',
            type: 'POST',
            data: formData,
            processData: false, 
            contentType: false, 
            dataType: 'json', 
            success: function(response) {
                 window.location.href = '/routes/edit/' + response.id;
            },
            error: function(xhr) {
                alert('Error: ' + xhr.responseText);
            },
            complete: function() {
                $submitBtn.prop('disabled', false).text("{{ 'save'|trans }}");
            }
        });
    });
});
</script>

{% endblock %}