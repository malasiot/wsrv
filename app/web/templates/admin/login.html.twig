{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.login.title'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="row justify-content-center align-items-center style-login-container" style="min-height: 70vh;">
    <div class="col-md-5 col-lg-4">
        
        <!-- Main Form Card Container -->
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4 p-md-5">
                
                <div class="text-center mb-4">
                    <span class="fs-1"></span>
                    <h3 class="fw-bold text-dark mt-2">{{ 'admin.login.heading'|trans }}</h3>
                    <p class="text-muted small">{{ 'admin.login.subheading'|trans }}</p>
                </div>

                <!-- Async Alert Presentation Container -->
                <div id="loginAlert" class="alert alert-danger d-none small py-2" role="alert"></div>

                <!-- Input Element Form Matrix -->
                <form id="adminLoginForm" 
                      data-msg-error-empty="{{ 'admin.login.error_empty'|trans }}"
                      data-msg-error-server="{{ 'admin.login.error_server'|trans }}">
                    
                    <!-- Username Form Control Field -->
                    <div class="form-floating mb-3">
                        <input type="text" 
                               name="username" 
                               id="username" 
                               class="form-control" 
                               placeholder="admin" 
                               required>
                        <label for="username">{{ 'admin.login.username_label'|trans }}</label>
                    </div>

                    <!-- Password Form Control Field -->
                    <div class="form-floating mb-4">
                        <input type="password" 
                               name="password" 
                               id="password" 
                               class="form-control" 
                               placeholder="••••••••" 
                               required>
                        <label for="password">{{ 'admin.login.password_label'|trans }}</label>
                    </div>

                    <!-- Authentication Action Trigger Button -->
                    <button class="btn btn-success btn-lg w-100 shadow-sm" type="submit">
                        <span id="loginSpinner" class="spinner-border spinner-border-sm me-2 d-none" role="status"></span>
                        {{ 'admin.login.submit_btn'|trans }}
                    </button>
                    
                </form>

            </div>
        </div>

        <div class="text-center mt-3">
            <a href="/" class="text-secondary small text-decoration-none">← {{ 'admin.login.back_to_site'|trans }}</a>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    <!-- Unique JavaScript validation layer for this page view only -->
    <script src="/public/js/admin-login.js"></script>
{% endblock %}