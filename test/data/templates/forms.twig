{% macro form(form) %}   

   <form {% if form.action is defined %}action="{{form.action}}"{% endif %} {% if form.method is defined %}method="{{form.method}}"{% endif %} {% if form.enctype is defined %}enctype="{{form.enctype}}"{% endif %}>
	{% include 'error-message' %} 
{% for field in form.fields %}
{% include field.widget ~ '_field' with field %}
{% endfor %}
    <button type="submit">Register</button>
</form>
{% endmacro %}

{% macro field(f, cls_ = [], attr_ = {}) %}
{% set cls = f.cls | merge(cls_) %}
{% set attr = f.attr | merge(attr_) %}
{% set field_ = f | merge( {cls: cls, attr: attr} ) %}
{% include f.widget ~ '_field' with field_ %}
{% endmacro %}